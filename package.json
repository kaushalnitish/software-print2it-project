{
  "name": "printflow-agent-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/dist/main/index.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && esbuild electron/main/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=electron/dist/main/index.cjs && esbuild electron/preload/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=electron/dist/preload/index.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist electron/dist release",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.printflow.agentv2",
    "productName": "PrintFlowAgentV2",
    "copyright": "Copyright © 2026 PrintFlow Systems",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PrintFlow Agent v2"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "auto-launch": "^5.0.6",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "express": "^4.21.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.8.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
